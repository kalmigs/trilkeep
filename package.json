{
  "name": "trilkeep",
  "displayName": "Trilkeep",
  "description": "Mirror your VSCode notes workspace into TriliumNext via the ETAPI.",
  "version": "0.0.1",
  "publisher": "kalmigs",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kalmigs/trilkeep.git"
  },
  "bugs": {
    "url": "https://github.com/kalmigs/trilkeep/issues"
  },
  "homepage": "https://github.com/kalmigs/trilkeep#readme",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "trilium",
    "triliumnext",
    "backup",
    "notes",
    "markdown",
    "etapi"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint src test",
    "test": "node --import tsx --test test/*.test.ts",
    "vscode:prepublish": "npm run compile",
    "package": "pnpm dlx @vscode/vsce@3.9.2 package",
    "publish:vsce": "pnpm dlx @vscode/vsce@3.9.2 publish",
    "publish:ovsx": "pnpm dlx ovsx@1.0.0 publish"
  },
  "contributes": {
    "commands": [
      {
        "command": "trilkeep.setup",
        "category": "Trilkeep",
        "title": "Setup"
      },
      {
        "command": "trilkeep.backup",
        "category": "Trilkeep",
        "title": "Back Up Workspace"
      },
      {
        "command": "trilkeep.previewBackup",
        "category": "Trilkeep",
        "title": "Back Up Workspace (Dry Run)"
      },
      {
        "command": "trilkeep.setToken",
        "category": "Trilkeep",
        "title": "Set ETAPI Token"
      },
      {
        "command": "trilkeep.testConnection",
        "category": "Trilkeep",
        "title": "Test Connection"
      },
      {
        "command": "trilkeep.clearToken",
        "category": "Trilkeep",
        "title": "Clear ETAPI Token"
      }
    ],
    "configuration": {
      "title": "Trilkeep",
      "properties": {
        "trilkeep.connectionName": {
          "type": "string",
          "default": "default",
          "description": "Stable name identifying this Trilium instance (e.g. \"real\", \"test\"). The ETAPI token and backup state (manifest) are keyed by this name, so serverUrl can change (e.g. a LAN IP) without losing the token or duplicating the backup. Use distinct names for distinct instances; leave as \"default\" for a single instance."
        },
        "trilkeep.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Base URL of your TriliumNext server (the ETAPI lives at <serverUrl>/etapi). Just the address — change it freely; identity is trilkeep.connectionName."
        },
        "trilkeep.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.md"
          ],
          "description": "Glob patterns for files to back up (relative to the workspace root)."
        },
        "trilkeep.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/.trilkeep/**"
          ],
          "description": "Glob patterns to exclude from backup."
        },
        "trilkeep.backupOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run an incremental backup automatically whenever a file is saved."
        },
        "trilkeep.rootNoteTitle": {
          "type": "string",
          "default": "Trilkeep",
          "description": "Title of the top-level Trilium note under which this workspace's tree is mirrored. The workspace folder name is appended automatically."
        },
        "trilkeep.hardDeleteRemovedFiles": {
          "type": "boolean",
          "default": false,
          "description": "If true, delete the Trilium note when a backed-up file is removed. Default false (soft): removed files are only logged, never auto-deleted."
        }
      }
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
